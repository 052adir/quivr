# --- Mentor Trade — environment configuration ---

# Where the SQLite database lives (relative to the backend/ folder by default)
DATABASE_URL=sqlite:///./mentor_trade.db

# Anthropic (Claude) — powers the AI tutor chat.
# Without a key the tutor falls back to canned lesson answers, so the app still runs.
ANTHROPIC_API_KEY=
# Default chat model. Sonnet keeps per-message cost low for a subscription product.
# Use claude-opus-4-8 for the most capable answers.
MENTOR_CHAT_MODEL=claude-sonnet-4-6

# Telegram — optional real-time alert channel so the bot reaches the user
# without them keeping any screen open. Leave blank to disable.
TELEGRAM_BOT_TOKEN=

# How often the background sync polls connected exchanges, in seconds.
SYNC_INTERVAL_SECONDS=60

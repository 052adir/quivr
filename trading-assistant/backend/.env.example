# --- Mentor Trade — environment configuration ---

MENTOR_ENV=development
# Where the SQLite database lives (relative to the backend/ folder by default)
DATABASE_URL=sqlite:///./mentor_trade.db
# Public base URL (used for Stripe redirect links)
APP_BASE_URL=http://localhost:8000

# Encryption key for stored exchange credentials (REQUIRED in production).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# If left blank in dev, a stable key is auto-generated to backend/.secret_key.
MENTOR_SECRET_KEY=

# Anthropic (Claude) — powers the AI tutor chat.
# Without a key the tutor falls back to canned lesson answers, so the app still runs.
ANTHROPIC_API_KEY=
# Default chat model. Sonnet keeps per-message cost low for a subscription product.
# Use claude-opus-4-8 for the most capable answers.
MENTOR_CHAT_MODEL=claude-sonnet-4-6

# Telegram — optional real-time alert channel.
TELEGRAM_BOT_TOKEN=

# Subscriptions (Stripe). Leave blank to run in trial-only mode (no charging).
TRIAL_DAYS=7
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Comma-separated CORS allowlist (blank = same-origin only).
CORS_ORIGINS=

# How often the background sync polls connected exchanges, in seconds.
SYNC_INTERVAL_SECONDS=60
